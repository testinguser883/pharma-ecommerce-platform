{
  "name": "pharma-ecommerce-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yast-ai/yast-template.git"
  },
  "bugs": {
    "url": "https://github.com/yast-ai/yast-template/issues"
  },
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "next dev",
    "dev:backend": "convex dev",
    "build": "convex deploy --cmd 'next build'",
    "start": "next start",
    "format": "prettier --write \"{app,components,convex,lib,types}/**/*.{ts,tsx,js,mjs,css,md}\" \"*.{json,ts,mjs,md}\"",
    "lint": "convex codegen && tsc --noEmit",
    "convex:codegen": "convex codegen"
  },
  "dependencies": {
    "@convex-dev/better-auth": "latest",
    "better-auth": "1.4.9",
    "clsx": "latest",
    "convex": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "next-themes": "^0.4.6",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "10.4.20",
    "eslint": "9.39.1",
    "eslint-config-next": "latest",
    "npm-run-all2": "latest",
    "postcss": "8.4.49",
    "prettier": "latest",
    "tailwindcss": "3.4.17",
    "typescript": "latest"
  }
}
