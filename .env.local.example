# Public app URL (used in redirects)
NEXT_PUBLIC_APP_URL=YOUR_APP_URL
NEXT_PUBLIC_SITE_URL=YOUR_APP_URL

# Convex deployment URLs
CONVEX_DEPLOYMENT_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Better Auth secret (generate a long random value)
BETTER_AUTH_SECRET=replace_with_a_secure_random_secret

# Convex Better Auth server-side URL reference
SITE_URL=YOUR_APP_URL

# NOWPayments crypto checkout
NOWPAYMENTS_API_KEY=YOUR_NOWPAYMENTS_API_KEY
NOWPAYMENTS_IPN_SECRET=YOUR_NOWPAYMENTS_IPN_SECRET

# Cloudflare Turnstile CAPTCHA (required — no bypass)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY

# Email (Resend — https://resend.com)
# Set these in Convex dashboard env vars too (Settings → Environment Variables)
RESEND_API_KEY=re_YOUR_RESEND_API_KEY
EMAIL_FROM=GetUrPill.com <orders@yourdomain.com>
